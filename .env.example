# Example .env for local development.
# Copy to .env and edit values before running `docker compose up`.

# PostgreSQL connection string used by the app. When running with Docker
# the hostname should be the service name defined in compose (`db`).
DATABASE_URL=postgres://postgres:postgres@db:5432/todos

# Optional Postgres vars used by the official image (only needed if you
# prefer creating the DB via env instead of a connection string above.)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=todos

# App listens on this port (mapped in compose)
PORT=3000